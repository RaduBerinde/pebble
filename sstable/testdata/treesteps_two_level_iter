# Test treesteps recording for twoLevelIterator SeekPrefixGE operation.
# This test builds an sstable with a two-level index (by using small block sizes)
# and performs a SeekPrefixGE operation while recording the operation steps with
# treesteps, then outputs the visualization URL.

build block-size=80 index-block-size=80
a@10#1,SET = valuea10
